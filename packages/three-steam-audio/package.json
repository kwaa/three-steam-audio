{
  "name": "three-steam-audio",
  "type": "module",
  "version": "0.1.0-beta.1",
  "description": "Steam Audio for Three.js and React Three Fiber.",
  "author": {
    "name": "藍+85CD",
    "url": "https://github.com/kwaa"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/kwaa/three-steam-audio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwaa/three-steam-audio.git",
    "directory": "packages/three-steam-audio"
  },
  "bugs": {
    "url": "https://github.com/kwaa/three-steam-audio/issues"
  },
  "keywords": [
    "3d-audio",
    "react-three-fiber",
    "spatial-audio",
    "steam-audio",
    "three.js",
    "webaudio",
    "webassembly"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./wasm": "./dist/bindings/phonon_bindings.wasm",
    "./wasm-runtime": {
      "types": "./dist/bindings/phonon_bindings.d.ts",
      "default": "./dist/bindings/phonon_bindings.js"
    },
    "./worklet": {
      "types": "./dist/steam-audio-processor.d.ts",
      "default": "./dist/steam-audio-processor.js"
    }
  },
  "files": [
    "THIRDPARTY.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "tsdown && vitest run",
    "typecheck": "tsc -p ../../tsconfig.app.json --noEmit"
  },
  "peerDependencies": {
    "@react-three/fiber": "^9.0.0",
    "react": "^19.0.0",
    "three": "^0.180.0"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@types/emscripten": "catalog:",
    "@types/react": "catalog:",
    "@types/three": "catalog:",
    "react": "catalog:",
    "three": "catalog:"
  }
}
