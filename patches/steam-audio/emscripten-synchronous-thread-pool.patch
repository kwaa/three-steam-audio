 void ThreadPool::process(JobGraph& jobGraph, std::function<void(float)> progressFn)
 {
+#if defined(__EMSCRIPTEN__)
+    mCancel = false;
+    mJobsCompleted = 0;
+    const auto numJobs = jobGraph.getNumJobs();
+    while (jobGraph.processNextJob(0, mCancel))
+    {
+        ++mJobsCompleted;
+        progressFn(numJobs > 0 ? (mJobsCompleted.load() * 1.0f) / numJobs : 1.0f);
+    }
+    if (numJobs == 0)
+        progressFn(1.0f);
